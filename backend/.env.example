# backend/.env.example
# Copy to backend/.env and fill in real values. NEVER commit backend/.env.

# --- Core ---
APP_NAME=ATLAS AI 2.0
ENVIRONMENT=development
DEBUG=true

# --- Database (MySQL, async) ---
# mysql+asyncmy://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+asyncmy://USER:PASSWORD@localhost:3306/atlasai

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-generate-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- AI provider models + routing ---
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-flash
CEREBRAS_MODEL=llama-3.3-70b
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
AI_PROVIDER_ORDER=groq,gemini,cerebras,sambanova
AI_REQUEST_TIMEOUT=30

# --- Voice (Interview Studio + Global Assistant only) ---
CHATTERBOX_TTS_URL=
ELEVENLABS_API_KEY=

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- v12 SkillPath Engine 3.0 ---
SKILLPATH_TOTAL_QUESTIONS=25
PRACTICE_AUTOGEN_ENABLED=true
SKILLPATH_V3_ENABLED=true




# --- AI Interview Studio: voice (v10) ---------------------------------------
# Self-hosted Chatterbox TTS (FastAPI wrapper: POST /speak {"text"} -> MP3).
# Leave blank until the container is deployed — voice degrades gracefully to
# browser speechSynthesis on the frontend.
CHATTERBOX_TTS_URL=
# Set to "elevenlabs" to enable the fallback (used ONLY if Chatterbox is down)
TTS_FALLBACK=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=


PYODIDE_CDN: str = "https://cdn.jsdelivr.net/pyodide/v0.26.4/full/"
COLAB_TEMPLATE_URL: str = ""
COPILOT_DAILY_CAP: int = 30
BYO_KEY_ENABLED: bool = False
# Google Sign-In (same Web client ID as the frontend's VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=


# --- v12 SkillPath Reforged (all deterministic caps; no new API keys) ---
V12_QUESTIONS_PER_SUBTOPIC=25
V12_MASTERY_CORRECT_THRESHOLD=20
V12_CORRECT_SCORE_THRESHOLD=60
# --- v12 Live Lab Pro ---
COPILOT_DAILY_CAP=40

# --- v12 seeding pipeline ---
SEED_CONCURRENCY=3
